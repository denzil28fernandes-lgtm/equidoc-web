# Copy this file to ".env.local" and paste your real key there.
# .env.local is git-ignored, so your key will NOT be pushed to GitHub.
#
# NOTE: no "VITE_" prefix on purpose — that keeps the key server-side only
# (used by the local proxy), so it never ends up in the browser bundle.

# Google AI Studio key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
